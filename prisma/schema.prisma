// D.C Funnel Bot - Prisma schema
// Database: PostgreSQL

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ----------------------------------------------------------------
// Enums
// ----------------------------------------------------------------

enum Role {
  // Legacy single-brand role, kept during PR #2 for safe migration compatibility.
  ADMIN
  AGENCY_ADMIN
  OWNER
  MANAGER
  SALE
  MARKETER
}

enum Stage {
  COLD
  WARM
  HOT
  CUSTOMER
  LOST
}

enum ConversationStatus {
  BOT_ACTIVE
  HUMAN_TAKEOVER
  CLOSED
}

enum MessageDirection {
  INBOUND
  OUTBOUND
  SYSTEM
}

enum SenderType {
  CUSTOMER
  BOT
  HUMAN
  AI
}

enum TriggerType {
  KEYWORD
  POSTBACK
  QUICK_REPLY
  DEFAULT
  STAGE
}

enum TaskType {
  FOLLOW_UP
  CALL
  CHECK_ORDER
  CUSTOM
}

enum TaskStatus {
  TODO
  DONE
  CANCELLED
}

enum OpportunityStatus {
  OPEN
  WON
  LOST
}

enum OrderStatus {
  DRAFT
  CONFIRMED
  PAID
  FULFILLING
  SHIPPED
  COMPLETED
  CANCELLED
  REFUNDED
}

enum PaymentStatus {
  UNPAID
  PARTIAL
  PAID
  REFUNDED
}

enum PaymentMethod {
  COD
  BANK_TRANSFER
  CASH
  OTHER
}

enum Industry {
  FASHION
  STUDIO
  SALON
  WEDDING
  SERVICE
  OTHER
}

enum FacebookPageStatus {
  CONNECTED
  MISSING_PERMISSION
  TOKEN_EXPIRED
  WEBHOOK_NOT_SUBSCRIBED
  DISCONNECTED
  ERROR
}

enum FacebookConnectionStatus {
  CONNECTED
  EXPIRED
  REVOKED
  ERROR
}

enum WebhookProcessingStatus {
  RECEIVED
  PROCESSED
  FAILED
  IGNORED
}

enum IntegrationAuditStatus {
  SUCCESS
  FAILED
}

enum FacebookCommentStatus {
  OPEN
  REPLIED
  HIDDEN
  ARCHIVED
}

enum AutomationTriggerType {
  CONTACT_CREATED
  CONTACT_STAGE_CHANGED
  OPPORTUNITY_CREATED
  OPPORTUNITY_STAGE_CHANGED
  ORDER_CREATED
  ORDER_STATUS_CHANGED
  COMMENT_CREATED
  COMMENT_HAS_PHONE
  TASK_DUE_SOON
  MANUAL_TEST
}

enum AutomationActionType {
  CREATE_TASK
  ADD_TAG
  UPDATE_CONTACT_STAGE
  CREATE_NOTE
  MARK_COMMENT_FOLLOWUP
  SEND_EMAIL
  WEBHOOK
  NOOP
}

enum AutomationRunStatus {
  SUCCESS
  FAILED
  SKIPPED
}

enum AutomationSourceType {
  CONTACT
  OPPORTUNITY
  ORDER
  COMMENT
  TASK
  MANUAL
}

// ----------------------------------------------------------------
// Models
// ----------------------------------------------------------------

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  role         Role     @default(SALE)
  name         String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  assignedConversations  Conversation[]    @relation("AssignedConversations")
  assignedTasks          Task[]            @relation("AssignedTasks")
  ownedCustomers         Customer[]        @relation("OwnedCustomers")
  ownedOpportunities     Opportunity[]     @relation("OwnedOpportunities")
  ownedOrders            Order[]           @relation("OwnedOrders")
  authoredNotes          Note[]            @relation("AuthoredNotes")
  createdAutomationRules AutomationRule[]  @relation("CreatedAutomationRules")
  workspaceMemberships   WorkspaceMember[]
}

model Organization {
  id        String    @id @default(cuid())
  name      String
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  workspaces Workspace[]

  @@index([deletedAt])
}

model Workspace {
  id             String    @id @default(cuid())
  organizationId String
  name           String
  industry       Industry  @default(OTHER)
  timezone       String    @default("Asia/Ho_Chi_Minh")
  currency       String    @default("VND")
  locale         String    @default("vi-VN")
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  deletedAt      DateTime?

  organization     Organization      @relation(fields: [organizationId], references: [id])
  members          WorkspaceMember[]
  facebookPages    FacebookPage[]
  facebookPosts    FacebookPost[]
  facebookComments FacebookComment[]
  customers        Customer[]
  conversations    Conversation[]
  messages         Message[]
  flows            Flow[]
  offers           Offer[]
  tasks            Task[]
  pipelines        Pipeline[]
  opportunities    Opportunity[]
  notes            Note[]
  products         ProductLite[]
  orders           Order[]
  automationRules  AutomationRule[]
  automationRuns   AutomationRun[]
  emailTemplates   EmailTemplate[]
  emailSequences   EmailSequence[]

  @@index([organizationId])
  @@index([deletedAt])
}

model WorkspaceMember {
  id           String   @id @default(cuid())
  workspaceId  String
  userId       String
  role         Role     @default(SALE)
  assignedOnly Boolean  @default(false)
  createdAt    DateTime @default(now())

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([workspaceId, userId])
  @@index([userId])
  @@index([role])
}

model BrandProfile {
  id              String   @id @default(cuid())
  brandName       String
  industry        Industry @default(OTHER)
  description     String?
  defaultTone     String?
  logoUrl         String?
  primaryColor    String?
  productServices String?
  salesPolicy     String?
  contactInfo     String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model FacebookConnection {
  id                   String                   @id @default(cuid())
  facebookUserId       String?
  facebookUserName     String?
  accessTokenEncrypted String?
  tokenType            String?
  expiresAt            DateTime?
  grantedScopes        String[]                 @default([])
  status               FacebookConnectionStatus @default(CONNECTED)
  createdAt            DateTime                 @default(now())
  updatedAt            DateTime                 @updatedAt

  pages FacebookPage[]

  @@index([status])
  @@index([facebookUserId])
}

model FacebookPage {
  id                       String             @id @default(cuid())
  workspaceId              String?
  pageId                   String             @unique
  pageName                 String
  pageUsername             String?
  pagePictureUrl           String?
  pageAccessTokenEncrypted String?
  tokenExpiresAt           DateTime?
  connectionId             String?
  botEnabled               Boolean            @default(false)
  webhookSubscribed        Boolean            @default(false)
  permissionsJson          Json?
  status                   FacebookPageStatus @default(CONNECTED)
  lastHealthCheckAt        DateTime?
  lastError                String?
  createdAt                DateTime           @default(now())
  updatedAt                DateTime           @updatedAt

  workspace     Workspace?          @relation(fields: [workspaceId], references: [id])
  connection    FacebookConnection? @relation(fields: [connectionId], references: [id])
  customers     Customer[]
  conversations Conversation[]
  messages      Message[]
  posts         FacebookPost[]
  comments      FacebookComment[]
  flows         Flow[]
  offers        Offer[]

  @@index([botEnabled])
  @@index([status])
  @@index([connectionId])
  @@index([workspaceId])
}

model FacebookWebhookLog {
  id               String                  @id @default(cuid())
  pageId           String?
  eventType        String?
  payloadJson      Json
  processingStatus WebhookProcessingStatus @default(RECEIVED)
  errorMessage     String?
  createdAt        DateTime                @default(now())

  @@index([pageId])
  @@index([processingStatus])
  @@index([createdAt])
}

model IntegrationAuditLog {
  id           String                 @id @default(cuid())
  provider     String
  action       String
  targetPageId String?
  status       IntegrationAuditStatus
  message      String?
  metadataJson Json?
  createdAt    DateTime               @default(now())

  @@index([provider])
  @@index([targetPageId])
  @@index([createdAt])
}

model FacebookPost {
  id                String    @id @default(cuid())
  workspaceId       String
  pageId            String
  externalPostId    String
  permalink         String?
  message           String?
  externalCreatedAt DateTime?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
  deletedAt         DateTime?

  workspace    Workspace         @relation(fields: [workspaceId], references: [id], onDelete: Restrict)
  facebookPage FacebookPage      @relation(fields: [pageId], references: [pageId], onDelete: Restrict)
  comments     FacebookComment[]

  @@unique([workspaceId, pageId, externalPostId])
  @@index([workspaceId])
  @@index([pageId])
  @@index([externalPostId])
  @@index([deletedAt])
}

model FacebookComment {
  id                String                @id @default(cuid())
  workspaceId       String
  pageId            String
  postId            String?
  customerId        String?
  conversationId    String?
  externalPostId    String
  externalCommentId String
  parentCommentId   String?
  message           String?
  fromName          String?
  fromId            String?
  permalink         String?
  status            FacebookCommentStatus @default(OPEN)
  hasPhone          Boolean               @default(false)
  needsFollowUp     Boolean               @default(false)
  isHidden          Boolean               @default(false)
  repliedAt         DateTime?
  hiddenAt          DateTime?
  externalCreatedAt DateTime?
  rawPayloadJson    Json?
  createdAt         DateTime              @default(now())
  updatedAt         DateTime              @updatedAt
  deletedAt         DateTime?

  workspace    Workspace     @relation(fields: [workspaceId], references: [id], onDelete: Restrict)
  facebookPage FacebookPage  @relation(fields: [pageId], references: [pageId], onDelete: Restrict)
  post         FacebookPost? @relation(fields: [postId], references: [id], onDelete: SetNull)
  customer     Customer?     @relation(fields: [customerId], references: [id], onDelete: SetNull)
  conversation Conversation? @relation(fields: [conversationId], references: [id], onDelete: SetNull)

  @@unique([workspaceId, pageId, externalCommentId])
  @@index([workspaceId])
  @@index([pageId])
  @@index([postId])
  @@index([customerId])
  @@index([conversationId])
  @@index([externalPostId])
  @@index([parentCommentId])
  @@index([status])
  @@index([hasPhone])
  @@index([needsFollowUp])
  @@index([createdAt])
  @@index([deletedAt])
}

model Customer {
  id               String    @id @default(cuid())
  workspaceId      String?
  ownerId          String?
  pageId           String?
  psid             String
  name             String?
  phone            String?
  gender           String?
  birthday         DateTime?
  address          String?
  customFieldsJson Json?
  avatarUrl        String?
  source           String?
  firstCampaign    String?
  firstPostId      String?
  currentStage     Stage     @default(COLD)
  leadScore        Int       @default(0)
  tags             String[]  @default([])

  // Email
  email          String?
  emailConsent   Boolean     @default(false)
  unsubscribedAt DateTime?
  emailStatus    EmailStatus @default(SUBSCRIBED)

  lastInteractionAt DateTime  @default(now())
  lastActivityAt    DateTime?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
  deletedAt         DateTime?

  conversations     Conversation[]
  funnelEvents      FunnelEvent[]
  tasks             Task[]
  opportunities     Opportunity[]
  orders            Order[]
  notes             Note[]
  facebookComments  FacebookComment[]
  emailLogs         EmailLog[]
  emailEnrollments  EmailAutomationEnrollment[]
  unsubscribeTokens UnsubscribeToken[]
  workspace         Workspace?                  @relation(fields: [workspaceId], references: [id])
  owner             User?                       @relation("OwnedCustomers", fields: [ownerId], references: [id], onDelete: SetNull)
  facebookPage      FacebookPage?               @relation(fields: [pageId], references: [pageId])

  @@unique([pageId, psid])
  @@index([currentStage])
  @@index([lastInteractionAt])
  @@index([lastActivityAt])
  @@index([email])
  @@index([ownerId])
  @@index([deletedAt])
  @@index([pageId])
  @@index([workspaceId])
}

model Note {
  id          String    @id @default(cuid())
  workspaceId String
  customerId  String
  authorId    String?
  body        String
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  deletedAt   DateTime?

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Restrict)
  customer  Customer  @relation(fields: [customerId], references: [id], onDelete: Restrict)
  author    User?     @relation("AuthoredNotes", fields: [authorId], references: [id], onDelete: SetNull)

  @@index([workspaceId])
  @@index([customerId])
  @@index([authorId])
  @@index([createdAt])
  @@index([deletedAt])
}

model Conversation {
  id            String             @id @default(cuid())
  workspaceId   String?
  pageId        String?
  customerId    String
  status        ConversationStatus @default(BOT_ACTIVE)
  assignedToId  String?
  lastMessageAt DateTime           @default(now())
  createdAt     DateTime           @default(now())
  updatedAt     DateTime           @updatedAt

  workspace        Workspace?        @relation(fields: [workspaceId], references: [id])
  customer         Customer          @relation(fields: [customerId], references: [id], onDelete: Cascade)
  facebookPage     FacebookPage?     @relation(fields: [pageId], references: [pageId])
  assignedTo       User?             @relation("AssignedConversations", fields: [assignedToId], references: [id])
  messages         Message[]
  facebookComments FacebookComment[]

  @@index([status])
  @@index([lastMessageAt])
  @@index([pageId])
  @@index([workspaceId])
}

model Message {
  id             String           @id @default(cuid())
  workspaceId    String?
  pageId         String?
  conversationId String
  direction      MessageDirection
  senderType     SenderType
  text           String?
  payloadJson    Json?
  metaMessageId  String?          @unique
  createdAt      DateTime         @default(now())

  workspace    Workspace?    @relation(fields: [workspaceId], references: [id])
  conversation Conversation  @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  facebookPage FacebookPage? @relation(fields: [pageId], references: [pageId])

  @@index([conversationId])
  @@index([createdAt])
  @@index([pageId])
  @@index([workspaceId])
}

model FunnelEvent {
  id         String   @id @default(cuid())
  pageId     String?
  customerId String
  eventName  String
  eventValue String?
  scoreDelta Int      @default(0)
  createdAt  DateTime @default(now())

  customer Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)

  @@index([customerId])
  @@index([eventName])
  @@index([pageId])
}

model Flow {
  id           String      @id @default(cuid())
  workspaceId  String?
  pageId       String?
  name         String
  triggerType  TriggerType
  triggerValue String?
  isActive     Boolean     @default(true)
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt

  steps        FlowStep[]
  workspace    Workspace?    @relation(fields: [workspaceId], references: [id])
  facebookPage FacebookPage? @relation(fields: [pageId], references: [pageId])

  @@index([pageId])
  @@index([workspaceId])
}

model FlowStep {
  id               String   @id @default(cuid())
  flowId           String
  key              String
  messageText      String
  quickRepliesJson Json?
  nextLogicJson    Json?
  scoreDelta       Int      @default(0)
  tagsToAdd        String[] @default([])
  stageToSet       Stage?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  flow Flow @relation(fields: [flowId], references: [id], onDelete: Cascade)

  @@unique([flowId, key])
  @@index([key])
}

model Offer {
  id            String        @id @default(cuid())
  workspaceId   String?
  pageId        String?
  product       String
  customerStage Stage?
  triggerTag    String?
  title         String
  description   String?
  priceText     String?
  offerText     String
  priority      Int           @default(0)
  isActive      Boolean       @default(true)
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  workspace     Workspace?    @relation(fields: [workspaceId], references: [id])
  facebookPage  FacebookPage? @relation(fields: [pageId], references: [pageId])

  @@index([isActive])
  @@index([triggerTag])
  @@index([pageId])
  @@index([workspaceId])
}

model Task {
  id           String     @id @default(cuid())
  workspaceId  String?
  customerId   String
  assignedToId String?
  type         TaskType   @default(FOLLOW_UP)
  title        String
  dueAt        DateTime?
  status       TaskStatus @default(TODO)
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  workspace  Workspace? @relation(fields: [workspaceId], references: [id])
  customer   Customer   @relation(fields: [customerId], references: [id], onDelete: Cascade)
  assignedTo User?      @relation("AssignedTasks", fields: [assignedToId], references: [id])

  @@index([status])
  @@index([dueAt])
  @@index([workspaceId])
}

model Pipeline {
  id               String    @id @default(cuid())
  workspaceId      String
  name             String
  industryTemplate String?
  isDefault        Boolean   @default(false)
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
  deletedAt        DateTime?

  workspace     Workspace       @relation(fields: [workspaceId], references: [id])
  stages        PipelineStage[]
  opportunities Opportunity[]

  @@index([workspaceId])
  @@index([deletedAt])
  @@index([isDefault])
}

model PipelineStage {
  id            String   @id @default(cuid())
  pipelineId    String
  name          String
  position      Int
  color         String?
  showInReports Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  pipeline      Pipeline      @relation(fields: [pipelineId], references: [id])
  opportunities Opportunity[]

  @@unique([pipelineId, position])
  @@index([pipelineId])
}

model Opportunity {
  id              String            @id @default(cuid())
  workspaceId     String
  customerId      String
  pipelineId      String
  stageId         String
  title           String
  valueVnd        Int               @default(0)
  status          OpportunityStatus @default(OPEN)
  ownerId         String?
  source          String?
  expectedCloseAt DateTime?
  lastActivityAt  DateTime?
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt
  closedAt        DateTime?
  deletedAt       DateTime?

  workspace Workspace     @relation(fields: [workspaceId], references: [id])
  customer  Customer      @relation(fields: [customerId], references: [id])
  pipeline  Pipeline      @relation(fields: [pipelineId], references: [id], onDelete: Restrict)
  stage     PipelineStage @relation(fields: [stageId], references: [id], onDelete: Restrict)
  owner     User?         @relation("OwnedOpportunities", fields: [ownerId], references: [id])
  orders    Order[]

  @@index([workspaceId])
  @@index([pipelineId])
  @@index([stageId])
  @@index([customerId])
  @@index([ownerId])
  @@index([status])
  @@index([deletedAt])
  @@index([expectedCloseAt])
}

model ProductLite {
  id          String    @id @default(cuid())
  workspaceId String
  name        String
  sku         String?
  priceVnd    Int       @default(0)
  description String?
  isActive    Boolean   @default(true)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  deletedAt   DateTime?

  workspace  Workspace   @relation(fields: [workspaceId], references: [id], onDelete: Restrict)
  orderItems OrderItem[]

  @@index([workspaceId])
  @@index([sku])
  @@index([isActive])
  @@index([deletedAt])
}

model Order {
  id              String         @id @default(cuid())
  workspaceId     String
  customerId      String
  opportunityId   String?
  ownerId         String?
  code            String
  status          OrderStatus    @default(DRAFT)
  paymentStatus   PaymentStatus  @default(UNPAID)
  paymentMethod   PaymentMethod?
  subtotalVnd     Int            @default(0)
  discountVnd     Int            @default(0)
  shippingFeeVnd  Int            @default(0)
  depositVnd      Int            @default(0)
  totalVnd        Int            @default(0)
  note            String?
  shippingName    String?
  shippingPhone   String?
  shippingAddress String?
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
  confirmedAt     DateTime?
  completedAt     DateTime?
  cancelledAt     DateTime?
  deletedAt       DateTime?

  workspace   Workspace    @relation(fields: [workspaceId], references: [id], onDelete: Restrict)
  customer    Customer     @relation(fields: [customerId], references: [id], onDelete: Restrict)
  opportunity Opportunity? @relation(fields: [opportunityId], references: [id], onDelete: SetNull)
  owner       User?        @relation("OwnedOrders", fields: [ownerId], references: [id], onDelete: SetNull)
  items       OrderItem[]

  @@unique([workspaceId, code])
  @@index([workspaceId])
  @@index([customerId])
  @@index([opportunityId])
  @@index([ownerId])
  @@index([status])
  @@index([paymentStatus])
  @@index([createdAt])
  @@index([deletedAt])
}

model OrderItem {
  id           String   @id @default(cuid())
  orderId      String
  productId    String?
  name         String
  sku          String?
  quantity     Int      @default(1)
  unitPriceVnd Int      @default(0)
  discountVnd  Int      @default(0)
  lineTotalVnd Int      @default(0)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  order   Order        @relation(fields: [orderId], references: [id], onDelete: Restrict)
  product ProductLite? @relation(fields: [productId], references: [id], onDelete: SetNull)

  @@index([orderId])
  @@index([productId])
}

model AutomationRule {
  id               String                @id @default(cuid())
  workspaceId      String
  name             String
  description      String?
  triggerType      AutomationTriggerType
  actionType       AutomationActionType
  conditionsJson   Json?
  actionConfigJson Json?
  isActive         Boolean               @default(true)
  runCount         Int                   @default(0)
  lastRunAt        DateTime?
  createdById      String?
  createdAt        DateTime              @default(now())
  updatedAt        DateTime              @updatedAt
  deletedAt        DateTime?

  workspace Workspace       @relation(fields: [workspaceId], references: [id], onDelete: Restrict)
  createdBy User?           @relation("CreatedAutomationRules", fields: [createdById], references: [id], onDelete: SetNull)
  runs      AutomationRun[]

  @@index([workspaceId])
  @@index([triggerType])
  @@index([actionType])
  @@index([isActive])
  @@index([createdById])
  @@index([deletedAt])
}

model AutomationRun {
  id          String                @id @default(cuid())
  workspaceId String
  ruleId      String
  triggerType AutomationTriggerType
  sourceType  AutomationSourceType?
  sourceId    String?
  status      AutomationRunStatus
  inputJson   Json?
  outputJson  Json?
  error       String?
  createdAt   DateTime              @default(now())

  workspace Workspace      @relation(fields: [workspaceId], references: [id], onDelete: Restrict)
  rule      AutomationRule @relation(fields: [ruleId], references: [id], onDelete: Restrict)

  @@index([workspaceId])
  @@index([ruleId])
  @@index([triggerType])
  @@index([sourceType])
  @@index([sourceId])
  @@index([status])
  @@index([createdAt])
}

// ----------------------------------------------------------------
// Email Automation
// ----------------------------------------------------------------

enum EmailStatus {
  SUBSCRIBED
  UNSUBSCRIBED
  BOUNCED
  COMPLAINED
}

enum EmailSequenceTrigger {
  TAG_ADDED
  STAGE_CHANGED
  FORM_SUBMITTED
  MANUAL
  PURCHASED
  BOOKING_CREATED
}

enum EnrollmentStatus {
  ACTIVE
  COMPLETED
  CANCELLED
}

enum EmailProviderName {
  RESEND
  SMTP
  GMAIL
  OTHER
}

enum EmailLogStatus {
  QUEUED
  SENT
  FAILED
  OPENED
  CLICKED
  BOUNCED
  COMPLAINED
}

model EmailTemplate {
  id            String   @id @default(cuid())
  workspaceId   String?
  name          String
  subject       String
  preheader     String?
  bodyHtml      String
  bodyText      String?
  variablesJson Json?
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  workspace     Workspace?          @relation(fields: [workspaceId], references: [id])
  sequenceSteps EmailSequenceStep[]
  emailLogs     EmailLog[]

  @@index([workspaceId])
}

model EmailSequence {
  id           String               @id @default(cuid())
  workspaceId  String?
  name         String
  description  String?
  triggerType  EmailSequenceTrigger
  triggerValue String?
  isActive     Boolean              @default(true)
  createdAt    DateTime             @default(now())
  updatedAt    DateTime             @updatedAt

  workspace   Workspace?                  @relation(fields: [workspaceId], references: [id])
  steps       EmailSequenceStep[]
  enrollments EmailAutomationEnrollment[]
  emailLogs   EmailLog[]

  @@index([triggerType])
  @@index([isActive])
  @@index([workspaceId])
}

model EmailSequenceStep {
  id             String   @id @default(cuid())
  sequenceId     String
  templateId     String
  delayMinutes   Int      @default(0)
  order          Int
  conditionsJson Json?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  sequence EmailSequence @relation(fields: [sequenceId], references: [id], onDelete: Cascade)
  template EmailTemplate @relation(fields: [templateId], references: [id])

  @@index([sequenceId])
}

model EmailAutomationEnrollment {
  id          String           @id @default(cuid())
  customerId  String
  sequenceId  String
  status      EnrollmentStatus @default(ACTIVE)
  currentStep Int              @default(0)
  nextRunAt   DateTime?
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  customer Customer      @relation(fields: [customerId], references: [id], onDelete: Cascade)
  sequence EmailSequence @relation(fields: [sequenceId], references: [id], onDelete: Cascade)

  @@index([status])
  @@index([nextRunAt])
  @@index([customerId, sequenceId])
}

model EmailLog {
  id                String            @id @default(cuid())
  customerId        String
  templateId        String?
  sequenceId        String?
  provider          EmailProviderName @default(RESEND)
  providerMessageId String?
  toEmail           String
  subject           String
  status            EmailLogStatus    @default(QUEUED)
  errorMessage      String?
  metadataJson      Json?
  sentAt            DateTime?
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt

  customer Customer       @relation(fields: [customerId], references: [id], onDelete: Cascade)
  template EmailTemplate? @relation(fields: [templateId], references: [id])
  sequence EmailSequence? @relation(fields: [sequenceId], references: [id])

  @@index([customerId])
  @@index([status])
  @@index([providerMessageId])
  @@index([createdAt])
}

model UnsubscribeToken {
  id         String    @id @default(cuid())
  customerId String
  tokenHash  String    @unique
  expiresAt  DateTime?
  createdAt  DateTime  @default(now())

  customer Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)

  @@index([customerId])
}
