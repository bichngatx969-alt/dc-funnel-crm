# ============================================================
# D.C Funnel Bot - Biến môi trường
# Copy file này thành .env rồi điền giá trị thật
# ============================================================

# --- Database (PostgreSQL) ---
# Ví dụ local: postgresql://postgres:postgres@localhost:5432/dc_funnel_bot?schema=public
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/dc_funnel_bot?schema=public"

# --- Meta Messenger Platform ---
# Facebook Login/OAuth cho kết nối Fanpage chính thống.
FACEBOOK_APP_ID=""
FACEBOOK_APP_SECRET=""
FACEBOOK_API_VERSION="v20.0"
FACEBOOK_LOGIN_REDIRECT_URI="http://localhost:3000/api/integrations/facebook/callback"
TOKEN_ENCRYPTION_SECRET=""

# Token bạn tự đặt, dùng để verify webhook (GET). Trùng với "Verify Token" khai báo trên Meta App.
META_VERIFY_TOKEN="dc-funnel-bot-verify-token"
# Page Access Token lấy từ Meta App (quyền pages_messaging).
META_PAGE_ACCESS_TOKEN=""
# App Secret để verify chữ ký X-Hub-Signature-256 (khuyến nghị, có thể để trống ở MVP).
META_APP_SECRET=""
# ID của Facebook Page kết nối.
FACEBOOK_PAGE_ID=""
# Phiên bản Graph API (mặc định v21.0 nếu để trống).
META_GRAPH_VERSION="v21.0"

# --- Vertical / Flow mặc định ---
# Chọn flow mặc định khi khách nhắn lần đầu: fashion | studio | salon
DEFAULT_VERTICAL="fashion"

# --- AI (tùy chọn) ---
# Nếu để trống, app vẫn chạy bình thường, chỉ ẩn nút "Gợi ý trả lời".
OPENAI_API_KEY=""
OPENAI_MODEL="gpt-4o-mini"

# --- Admin login (MVP) ---
ADMIN_EMAIL="admin@dcgroup.vn"
ADMIN_PASSWORD="changeme123"
ADMIN_NAME="Admin D.C"

# --- Auth session ---
# Chuỗi bí mật ký cookie phiên đăng nhập. Đổi sang chuỗi ngẫu nhiên khi deploy.
AUTH_SECRET="please-change-this-to-a-long-random-string"

# --- App ---
# URL gốc của app, dùng để tạo link unsubscribe trong email.
APP_BASE_URL="http://localhost:3000"

# --- Email automation (Resend) ---
# Nếu để trống RESEND_API_KEY (hoặc EMAIL_FROM_ADDRESS) thì chức năng gửi email bị tắt, app vẫn chạy.
RESEND_API_KEY=""
# Secret để verify webhook Resend (Svix). Tùy chọn.
RESEND_WEBHOOK_SECRET=""
EMAIL_FROM_NAME="D.C Funnel Bot"
# Phải là email thuộc domain đã verify trên Resend, ví dụ: no-reply@yourdomain.com
EMAIL_FROM_ADDRESS=""
# Chuỗi bí mật ký token unsubscribe.
UNSUBSCRIBE_SECRET="please-change-this-to-a-long-random-string"

# --- Cron ---
# Bí mật bảo vệ endpoint POST /api/cron/email-automation
CRON_SECRET="please-change-this-cron-secret"
